#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION="$(python3 "$SCRIPT_DIR/version_info.py")"

show_help() {
  cat <<EOF
attention - attention repo CLI (v${VERSION})

USAGE:
  attention <command> [args]

COMMANDS:
  init [repo-path] [--include-skills] [--include-plugins] [--dry-run]
  init-config [--force]
  bootstrap-update
  start [repo-path] [task...]
  wrap <repo-path>
  declare-intent <repo-path> --affected-entities ... --deployment-pipeline ... --first-principle-summary ... --requires-new-entity true|false [--task-type code|docs|tests]
  assemble <repo-path>
  update-task <repo-path> --status-markdown "..."
  register-new-entity <repo-path> --id ... --type ... --file-path ... --ci-cd ... --endpoint ... --description ...
  map-freshness-check <repo-path> [--no-change-justification "..."]
  finalize-change <repo-path> [--tests-command ...] [--tests-result pass|fail|not_run] [--notes ...]
  clear-task <repo-path>
  reinit <repo-path> [--no-salvage-task] [--no-auto-assemble]
  release-attention <repo-path> [--note "..."]
  sync-state <repo-path> [--version X.Y.Z] [--description "..."]
  repair
  reindex

EXAMPLES:
  attention init-config
  attention init --dry-run
  attention init
  attention bootstrap-update
  attention start
  attention start . "Summarize the new central config/index flow and trim stale menu paths."
  attention wrap .
  attention declare-intent ~/code/repo --affected-entities E-AUTH-1 --deployment-pipeline .github/workflows/api.yml --first-principle-summary "Validate JWT signature and emit auth verdict" --requires-new-entity false
  attention assemble ~/code/repo
  attention update-task ~/code/repo --status-markdown "Mapped entities and started auth middleware edits."
  attention sync-state . --description "Local-first workflow state sync"
EOF
}

show_update_gate() {
  python3 - "$SCRIPT_DIR" <<'PY'
import sys

sys.path.insert(0, sys.argv[1])

from resolve import get_update_gate_status
from version_info import get_version

gate = get_update_gate_status(get_version())
if gate["required"]:
    print(gate["message"])
    raise SystemExit(0)
raise SystemExit(1)
PY
}

if [ $# -lt 1 ]; then
  show_help
  exit 1
fi

cmd="$1"
shift

case "$cmd" in
  bootstrap-update|init-config|-h|--help|help)
    ;;
  *)
    if show_update_gate; then
      exit 1
    fi
    ;;
esac

case "$cmd" in
  init)
    python3 "$SCRIPT_DIR/jit-context.py" init "$@"
    ;;
  init-config)
    python3 "$SCRIPT_DIR/jit-context.py" init-config "$@"
    ;;
  bootstrap-update)
    python3 "$SCRIPT_DIR/jit-context.py" bootstrap-update "$@"
    ;;
  start)
    repo="."
    if [ $# -ge 1 ]; then
      repo="$1"
      shift
    fi
    python3 "$SCRIPT_DIR/jit-context.py" reindex >/dev/null 2>&1 || true
    resolved_repo="$(python3 - "$SCRIPT_DIR" "$repo" <<'PY'
import sys
from pathlib import Path

sys.path.insert(0, sys.argv[1])
from resolve import resolve_project_path

repo_arg = sys.argv[2]
path = Path(repo_arg).expanduser()
if path.exists():
    print(path.resolve())
else:
    print(resolve_project_path(repo_arg))
PY
)"
    # Set global attention state
    python3 "$SCRIPT_DIR/attention-state.py" set "$resolved_repo"
    if [ $# -eq 0 ]; then
      echo "Project focus: $resolved_repo"
      if [ -f "$resolved_repo/CURRENT_TASK.md" ]; then
        echo
        sed -n '1,160p' "$resolved_repo/CURRENT_TASK.md"
      else
        echo "No active task yet."
      fi
      echo
      echo "Reply with what you want to work on next, or run:"
      echo "  attention start $repo \"<task>\""
      exit 0
    fi
    task="$*"
    python3 "$SCRIPT_DIR/jit-context.py" update-task "$repo" --status-markdown "$task"
    python3 "$SCRIPT_DIR/jit-context.py" assemble "$repo"
    ;;
  declare-intent)
    python3 "$SCRIPT_DIR/jit-context.py" declare-intent "$@"
    ;;
  assemble)
    python3 "$SCRIPT_DIR/jit-context.py" assemble "$@"
    ;;
  update-task)
    python3 "$SCRIPT_DIR/jit-context.py" update-task "$@"
    ;;
  register-new-entity)
    python3 "$SCRIPT_DIR/jit-context.py" register-new-entity "$@"
    ;;
  map-freshness-check)
    python3 "$SCRIPT_DIR/jit-context.py" map-freshness-check "$@"
    ;;
  finalize-change)
    python3 "$SCRIPT_DIR/jit-context.py" finalize-change "$@"
    ;;
  clear-task)
    python3 "$SCRIPT_DIR/jit-context.py" clear-task "$@"
    ;;
  reinit)
    python3 "$SCRIPT_DIR/jit-context.py" reinit "$@"
    ;;
  release-attention)
    python3 "$SCRIPT_DIR/jit-context.py" release-attention "$@"
    # Clear global attention state
    python3 "$SCRIPT_DIR/attention-state.py" release "$@"
    ;;
  sync-state)
    python3 "$SCRIPT_DIR/jit-context.py" sync-state "$@"
    ;;
  wrap)
    if [ $# -lt 1 ]; then
      echo "Usage: attention wrap <repo-path>"
      exit 1
    fi
    repo="$1"
    shift
    python3 "$SCRIPT_DIR/jit-context.py" map-freshness-check "$repo" "$@"
    python3 "$SCRIPT_DIR/jit-context.py" finalize-change "$repo" --tests-result not_run --notes "Wrapped via attention CLI"
    python3 "$SCRIPT_DIR/jit-context.py" sync-state "$repo" --description "Wrap-up sync via attention CLI"
    python3 "$SCRIPT_DIR/jit-context.py" release-attention "$repo" --note "Released via attention CLI wrap flow"
    # Clear global attention state
    python3 "$SCRIPT_DIR/attention-state.py" release
    ;;
  repair)
    python3 "$SCRIPT_DIR/jit-context.py" repair "$@"
    ;;
  reindex)
    python3 "$SCRIPT_DIR/jit-context.py" reindex "$@"
    ;;
  -h|--help|help)
    show_help
    ;;
  *)
    echo "Unknown command: $cmd"
    echo "Run: attention --help"
    exit 1
    ;;
esac
