#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

show_help() {
  cat <<'EOF'
attention - lean attention layer CLI (v3)

USAGE:
  attention <command> [args]

COMMANDS:
  init <repo-path>
  declare-intent <repo-path> --affected-entities ... --deployment-pipeline ... --first-principle-summary ... --requires-new-entity true|false [--task-type code|docs|tests]
  assemble <repo-path>
  update-task <repo-path> --status-markdown "..."
  register-new-entity <repo-path> --id ... --type ... --file-path ... --ci-cd ... --endpoint ... --description ...
  map-freshness-check <repo-path> [--no-change-justification "..."]
  finalize-change <repo-path> [--tests-command ...] [--tests-result pass|fail|not_run] [--notes ...]
  clear-task <repo-path>
  sync-state <repo-path> [--version X.Y.Z] [--description "..."]

EXAMPLES:
  attention declare-intent ~/code/repo --affected-entities E-AUTH-01 --deployment-pipeline .github/workflows/api.yml --first-principle-summary "Validate JWT signature and emit auth verdict" --requires-new-entity false
  attention assemble ~/code/repo
  attention update-task ~/code/repo --status-markdown "Mapped entities and started auth middleware edits."
  attention sync-state . --version 3.2.4 --description "Menu-first UX with Telegram inline keyboards"
EOF
}

if [ $# -lt 1 ]; then
  show_help
  exit 1
fi

cmd="$1"
shift

case "$cmd" in
  init)
    python3 "$SCRIPT_DIR/jit-context.py" init "$@"
    ;;
  declare-intent)
    python3 "$SCRIPT_DIR/jit-context.py" declare-intent "$@"
    ;;
  assemble)
    python3 "$SCRIPT_DIR/jit-context.py" assemble "$@"
    ;;
  update-task)
    python3 "$SCRIPT_DIR/jit-context.py" update-task "$@"
    ;;
  register-new-entity)
    python3 "$SCRIPT_DIR/jit-context.py" register-new-entity "$@"
    ;;
  map-freshness-check)
    python3 "$SCRIPT_DIR/jit-context.py" map-freshness-check "$@"
    ;;
  finalize-change)
    python3 "$SCRIPT_DIR/jit-context.py" finalize-change "$@"
    ;;
  clear-task)
    python3 "$SCRIPT_DIR/jit-context.py" clear-task "$@"
    ;;
  sync-state)
    python3 "$SCRIPT_DIR/jit-context.py" sync-state "$@"
    ;;
  -h|--help|help)
    show_help
    ;;
  *)
    echo "Unknown command: $cmd"
    echo "Run: attention --help"
    exit 1
    ;;
esac
