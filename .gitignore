.gitignore

# Attention Repo working state (local per-repo control plane)
\!MAP.md
CURRENT_TASK.md
.attention/
.attention/canonical-route.json
attention-config.json
node_modules/
.claude/
*.bun-build
mcp-server/attention-repo-mcp

# Track GitHub Actions workflows; ignore everything else under .github/
!.github/
!.github/workflows/
.github/workflows/*
!.github/workflows/entity/
!.github/workflows/canonical/
!.github/workflows/ci.yml
!.github/workflows/E-ATTN-*.yml

_archive/
docs/
references/
scripts/
Tests/
!scripts/
!scripts/__init__.py
!scripts/attention
!scripts/attention-state.py
!scripts/attention_state.py
!scripts/jit-context.py
!scripts/jit_context.py
!scripts/resolve.py
!scripts/version_info.py
!tests/
!tests/conftest.py
!tests/test_*.py
!tests/test_*.js

NEXT_STEPS_UNTESTED.md
__pycache__/

# Agent-specific files (may contain personal context)
*AGENT*.md
CLAUDE.md
.mcp.json
wrangler.toml

# OS files
.DS_Store

# Local/internal notes and generated reports
notes/
tests/*.md

# Local benchmark/migration helpers not shipped in the package
scripts/generate_case_charts.py
scripts/migrate-map.py
scripts/summarize_case_results.py

# Research notes (internal, not for repo)
# Stored in: ~/.openclaw/workspace/notes/attention-research/
