{
  "$schema": "attention-repo-config-v3",
  "openclaw": {
    "config_path": "~/.openclaw/openclaw.json",
    "inherit_workspace_root": true,
    "inherit_default_model": true,
    "inherit_available_models": true
  },
  "paths": {
    "state_root": "~/.openclaw/attention-repo",
    "default_scan_roots": [
      "~/.openclaw/workspace/projects"
    ],
    "optional_scan_roots": {
      "skills": "~/.openclaw/workspace/skills",
      "plugins": "~/.openclaw/plugins"
    }
  },
  "discovery": {
    "mode": "projects_only",
    "max_depth": 1,
    "candidate_markers": [
      ".git",
      "package.json",
      "pyproject.toml",
      "Cargo.toml",
      "go.mod",
      "README.md"
    ],
    "include_skills_only_when_requested": true,
    "include_plugins_only_when_requested": true,
    "menu_visible_scopes": [
      "projects",
      "skills"
    ]
  },
  "models": {
    "default": "auto",
    "fallbacks": "openclaw",
    "available": [],
    "tasks": {
      "architectural_analysis": "auto",
      "code_generation": "auto",
      "documentation": "auto"
    },
    "resolved": {
      "openclaw_default": "auto",
      "openclaw_fallbacks": []
    }
  },
  "projects": {
    "my-project": {
      "canonical_path": "/absolute/path/to/project",
      "source": "projects",
      "scope": "projects",
      "managed": true,
      "entity_resolution": {
        "map_path": "/absolute/path/to/project/!MAP.md",
        "task_path": "/absolute/path/to/project/CURRENT_TASK.md"
      }
    }
  }
}
