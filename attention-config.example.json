{
  "$schema": "attention_repo-config-v1",
  "skill_root": ".",
  "project_registry": {
    "my-project": {
      "canonical_path": "/path/to/your/project",
      "git_remote": "https://github.com/yourusername/your-project.git",
      "source_strategy": "local_only",
      "entity_resolution": {
        "!MAP.md": "${canonical_path}/!MAP.md"
      }
    },
    "another-project": {
      "canonical_path": "/path/to/another/project",
      "source_strategy": "local_only"
    }
  },
  "path_resolution": {
    "order": ["canonical_path", "workspace_projects", "git_clone"],
    "workspace_projects_root": "/path/to/your/workspace/projects",
    "fallback_behavior": "fail_with_config_hint"
  },
  "model_usage": {
    "default": "minimax-portal/MiniMax-M2.5",
    "tasks": {
      "architectural_analysis": "kimi-coding/k2p5",
      "code_generation": "minimax-portal/MiniMax-M2.5",
      "documentation": "minimax-portal/MiniMax-M2.5"
    }
  },
  "validation": {
    "require_canonical_path_exists": true,
    "require_git_remote_for_clone": true,
    "forbid_disk_wide_search": true
  }
}
